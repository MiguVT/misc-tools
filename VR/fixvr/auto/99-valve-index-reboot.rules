# Valve Index HMD: fix blank EDID
# Works around blank EDID bug that makes the kernel see the HMD as a 640x480 monitor.
# Sends a HID reboot command once per boot when the device is enumerated.
# /tmp is cleared on boot so the flag resets automatically.

KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="28de", MODE="0666", TAG+="uaccess"
SUBSYSTEM=="usb", ATTRS{idVendor}=="28de", MODE="0666", TAG+="uaccess"

KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="28de", ATTRS{idProduct}=="2300", ACTION=="add", RUN+="/bin/sh -c 'test -f /tmp/.valve-index-rebooted || { printf \"\\x16\\x01\" | cat - /dev/zero | head -c 64 > /dev/%k; touch /tmp/.valve-index-rebooted; }'"
